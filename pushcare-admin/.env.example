# Supabase Auth (browser: anon key only). Lists/campaigns/devices come from REST unless VITE_PUSHCARE_DATA_SOURCE is unset (auto → Postgres).
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# PushCare REST API (production or backends/local-api).
# VITE_PUSHCARE_API_URL=https://api.pushcare.net
# VITE_PUSHCARE_API_URL=http://localhost:8787
# With Supabase Auth: use rest so dashboard reads API (not empty Postgres). JWT is sent as Bearer.
# VITE_PUSHCARE_DATA_SOURCE=rest

# Create Auth + app_owners for dashboard login (once per env):
#   Put SUPABASE_SERVICE_ROLE_KEY in backends/.env (never commit). Then:
#   npm run create-dashboard-user
# Optional: CREATE_ADMIN_EMAIL CREATE_ADMIN_PASSWORD for non-default test accounts.
# After that, same-machine check (anon sign-in, same as the browser):
#   npm run verify-login
