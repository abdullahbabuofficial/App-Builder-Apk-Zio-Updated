# Supabase (browser uses anon key + JWT only; never put service_role here).
# When both are set and you sign in with Supabase Auth, the dashboard reads/writes via RLS.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: PushCare REST API (backends/local-api). Used without a Supabase session, or when Supabase env is unset.
# VITE_PUSHCARE_API_URL=http://localhost:8787
