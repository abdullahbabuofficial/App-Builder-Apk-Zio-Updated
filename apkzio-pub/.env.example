# Copy to `.env.local` (ignored by git). Vite exposes only variables prefixed with VITE_.

# --- REST API the dashboard calls (required for live auth, apps, builds, builder). ---
# Dev: run backends/local-api then point here. Prod: your deployed API origin (no trailing slash).
VITE_APKZIO_API_URL=http://127.0.0.1:8787

# Optional: production API
# VITE_APKZIO_API_URL=https://your-api.example.com

# --- Supabase (same project as backends/.env — keeps MCP + CLI + DB aligned) ---
# Dashboard → Project Settings → API. Use the anon (public) key only here.
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=

# --- Firebase (Analytics / FCM / Google sign-in on Login & Register) ---
# Firebase Console → Project settings → Your apps → Web app config.
# Authentication → Sign-in method → enable Google.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# Optional: VITE_FIREBASE_MEASUREMENT_ID=  VITE_FIREBASE_VAPID_KEY=
#
# Backend must verify tokens: set FIREBASE_SERVICE_ACCOUNT_JSON (or PATH) on local-api.
