{
  "name": "@apkzio/firebase-dispatcher",
  "version": "1.0.0",
  "description": "ApkZio FCM dispatcher — polls the queue, sends push, records delivery.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "pg": "^8.13.0",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "eslint": "^9.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
