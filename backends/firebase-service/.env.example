# PushCare FCM dispatcher — env template
#
# Copy to `.env` and fill in. Production should source these from your
# secret manager (Doppler / Vault / AWS SSM / Fly secrets / etc.).

# ---------------------------------------------------------------------
# Postgres (Supabase): use the *direct* connection string for the
# dispatcher, not the pooler. We need session-level features (FOR UPDATE
# SKIP LOCKED, prepared statements). Pooler is fine for Edge Functions.
#
# Find this at: Supabase Dashboard → Project Settings → Database →
# "Connection string" → URI (Direct).
# ---------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require

# pg pool size per worker process. Multiply by WORKER_CONCURRENCY to get
# total connections used by this pod. Stay well below your Supabase
# instance's max_connections.
PG_POOL_MAX=5

# ---------------------------------------------------------------------
# Firebase
# ---------------------------------------------------------------------
# Default service-account JSON (one line). Used when an app doesn't
# carry per-tenant fcm_credentials.
DEFAULT_FCM_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ---------------------------------------------------------------------
# Worker tuning
# ---------------------------------------------------------------------
WORKER_CONCURRENCY=4         # campaigns dispatched in parallel per pod
POLL_INTERVAL_MS=2000        # poll cadence when queue is empty

# ---------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------
LOG_LEVEL=info               # debug | info | warn | error
NODE_ENV=production
PORT=8080
