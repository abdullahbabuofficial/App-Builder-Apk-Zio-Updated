{
  "name": "@apkzio/local-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "In-memory ApkZio API for local dev — SDK, dashboard REST, simulated dispatch.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "e2e:assemble": "tsx scripts/e2e-assemble-debug.mts"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "firebase-admin": "^13.5.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
