{
  "name": "@apkzio/local-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "In-memory ApkZio API for local dev — SDK, dashboard REST, simulated dispatch.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:aggregation": "tsx src/test-aggregation.ts",
    "test:webhook-server": "tsx src/webhooks/test-webhook-server.ts",
    "e2e:assemble": "tsx scripts/e2e-assemble-debug.mts",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "security:audit": "tsx scripts/security-audit.ts",
    "load-test": "k6 run load-tests/api-stress-test.js",
    "load-test:campaign": "k6 run load-tests/campaign-stress.js",
    "load-test:autocannon": "tsx load-tests/autocannon-test.ts",
    "benchmark": "tsx benchmarks/benchmark.ts",
    "analyze-queries": "psql $DATABASE_URL -f scripts/analyze-slow-queries.sql"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@sentry/node": "^10.52.0",
    "@sentry/tracing": "^7.120.4",
    "@stripe/stripe-js": "^9.4.0",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.1",
    "firebase-admin": "^13.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^2.30.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^22.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
