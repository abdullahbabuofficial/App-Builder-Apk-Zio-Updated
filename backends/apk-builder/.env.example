# PushCare APK builder — env template
#
# Copy to `.env` and fill in. Production should source these from your
# secret manager (Doppler / Vault / AWS SSM / Fly secrets / etc.).

# ---------------------------------------------------------------------
# Pick ONE: Postgres mode OR Local-API mode.
# ---------------------------------------------------------------------

# Postgres mode (production):
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
PG_POOL_MAX=3

# Local-API mode (dev — talk to backends/local-api):
# LOCAL_API_URL=http://localhost:8787

# ---------------------------------------------------------------------
# Supabase Storage for APK upload (optional — falls back to local disk).
# ---------------------------------------------------------------------
# SUPABASE_URL=https://<PROJECT-REF>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Local fallback if no Supabase Storage.
OUTPUT_DIR=/tmp/pushcare-apk-out

# ---------------------------------------------------------------------
# Build mode
# ---------------------------------------------------------------------
# `simulated` (default) — produces a real ZIP shaped like an APK.
# `gradle`              — runs `bash gradlew assembleRelease` in a copy
#                         of templates/android-app/. Requires JDK 17 +
#                         Android SDK + gradle 8.7+ on PATH.
APK_BUILD_MODE=simulated

# Path to the Android template project. Override only for development.
# APK_TEMPLATE_DIR=

# Per-tenant release-signing keystore (gradle mode). Drop a JKS at
# <workdir>/keystores/release.jks before assembleRelease, or set these
# env vars to inject a worker-level signing identity.
# PUSHCARE_KEYSTORE_PASSWORD=
# PUSHCARE_KEY_ALIAS=release
# PUSHCARE_KEY_PASSWORD=

# ---------------------------------------------------------------------
# Worker tuning
# ---------------------------------------------------------------------
WORKER_CONCURRENCY=2          # builds processed in parallel per pod
POLL_INTERVAL_MS=5000         # poll cadence when queue is empty

# ---------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------
LOG_LEVEL=info                # debug | info | warn | error
NODE_ENV=production
PORT=8090
