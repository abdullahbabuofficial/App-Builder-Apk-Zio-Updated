# Copy to `backends/.env` (do not commit real secrets).
# `backends/local-api` loads this file automatically on startup, then `backends/local-api/.env` if present.

# =============================================================================
# Golden path — ONE Supabase project wires DB + Edge + MCP + frontends
# =============================================================================
# 1) Set SUPABASE_PROJECT_REF below, then from repo root run:
#      make supabase-env-hints SUPABASE_PROJECT_REF=<your_ref>
#    Paste printed lines into backends/.env, firebase-service/.env, apkzio-admin/.env.local,
#    apkzio-pub/.env.local — then fill passwords/keys from the Supabase Dashboard.
#
# 2) Cursor: edit `.cursor/mcp.json` — replace YOUR_PROJECT_REF — sign in when MCP prompts.
#
# 3) Dispatcher (real Postgres queue): `backends/firebase-service` requires DATABASE_URL
#    (Direct connection URI, port 5432). Same DB as Supabase migrations in `supabase/migrations/`.
#
# =============================================================================
# Local dev — in-memory API (no Postgres) for fast UI work
# =============================================================================
# 1) Start API: cd backends/local-api && npm run dev  →  http://127.0.0.1:8787
#
# 2) apkzio-admin — apkzio-admin/.env.local:
#      VITE_APKZIO_API_URL=http://127.0.0.1:8787
#      VITE_APKZIO_DATA_SOURCE=rest
#    Optional: VITE_SUPABASE_* for real auth — see apkzio-admin/.env.example
#
# 3) apkzio-pub — apkzio-pub/.env.local:
#      VITE_APKZIO_API_URL=http://127.0.0.1:8787
#    Optional: VITE_SUPABASE_* (same project as admin) — see apkzio-pub/.env.example
#
# CORS: use 127.0.0.1 or localhost consistently with the Vite dev URL.

# --- local-api (optional overrides) ---
PORT=8787
# APK builds: unset = auto when java+gradle+ANDROID_HOME exist; 1 = explicit; 0 = ZIP-only.
# Output is always a debug APK (install on device — not Play Store).
# APKZIO_ENABLE_APK_BUILD=
# ANDROID_HOME=/path/to/Android/sdk
# APKZIO_GRADLE_TASK=assembleDebug
# APKZIO_GRADLE_TIMEOUT_MS=1200000
# APKZIO_GRADLE_HEAP=2g
# APKZIO_MAX_CONCURRENT_GRADLE=1
# APKZIO_TRUST_PROXY=1
# APKZIO_BUILDER_RATE_LIMIT_MAX=30
# APKZIO_BUILDER_RATE_LIMIT_WINDOW_MS=60000
# APKZIO_SERVICE_KEY=
# APKZIO_ADMIN_API_KEY=
# ENFORCE_ADMIN_AUTH=0
# NODE_ENV=development

# =============================================================================
# Supabase (optional — Auth + dashboard scripts). Use placeholders in commits.
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Dashboard / CLI (never commit real tokens)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# =============================================================================
# Firebase Admin (local-api) — FCM + verify Google ID tokens for apkzio-pub
# =============================================================================
# Same service account JSON you use for FCM. Required for POST /api/auth/google.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or: FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
# FIREBASE_PROJECT_ID=your-project-id
#
# Firebase Console → Authentication → Sign-in method → enable Google.
# Authorized domains: add your pub site host (e.g. apkzio.com) and localhost for dev.

# -----------------------------------------------------------------------------
# GitHub Actions: if your repo uses shorter secret names, map them in CI or here
# -----------------------------------------------------------------------------
#   SB_ACCESS_TOKEN        → SUPABASE_ACCESS_TOKEN (or CLI only)
#   SB_ANON_KEY            → SUPABASE_ANON_KEY  (+ VITE_SUPABASE_ANON_KEY in frontends)
#   SB_SECRET_KEY          → SUPABASE_SECRET_KEY
#   SB_SERVICE_ROLE_KEY    → SUPABASE_SERVICE_ROLE_KEY
# In GitHub: Settings → Secrets and variables → Actions — paste values there;
# for local `.env`, copy the same strings into the SUPABASE_* names above.
