# Template only — copy to `.env` and fill with YOUR values.
# Never put real passwords or API tokens in `.env.example` (this file is usually committed).
# If secrets were ever pasted here or shared: rotate them in Supabase / Firebase immediately.

# --- Supabase project ---
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_PROJECT_REF=<PROJECT_REF>

# Supabase CLI / Management API (personal access token from dashboard — keep secret)
SUPABASE_ACCESS_TOKEN=

# Database (direct connection password from Dashboard → Database → Database password)
SUPABASE_DB_PASSWORD=

# PostgREST / supabase-js (Dashboard → Project Settings → API)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: newer API keys if your project uses them
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
