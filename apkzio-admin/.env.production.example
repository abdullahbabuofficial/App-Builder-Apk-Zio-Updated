# ApkZio Admin Production Environment
# Copy this to .env.production and configure

# Data Source (NEVER use 'mock' in production!)
VITE_APKZIO_DATA_SOURCE=rest  # or 'supabase'

# REST API (required if using data source 'rest')
VITE_APKZIO_API_URL=https://api.apkzio.com
VITE_APKZIO_ADMIN_API_KEY=  # Optional, for admin routes

# Supabase (required if using data source 'supabase')
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (optional, for error tracking)
VITE_SENTRY_DSN=
