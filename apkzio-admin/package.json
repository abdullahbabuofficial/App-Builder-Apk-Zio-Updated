{
  "name": "apkzio-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ApkZio admin console — control plane for push, devices, campaigns, and analytics.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.mjs && tsc -b && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "verify:ui": "node scripts/verify-admin-ui.mjs",
    "create-dashboard-user": "node scripts/create-dashboard-user.mjs",
    "verify-login": "node scripts/verify-supabase-login.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
