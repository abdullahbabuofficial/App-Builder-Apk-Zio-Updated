# Copy to `.env.local` (ignored by git). Vite exposes only variables prefixed with VITE_.

# =============================================================================
# Localhost — connect dashboard to backends/local-api
# =============================================================================
VITE_APKZIO_API_URL=http://127.0.0.1:8787
# Use REST lists/campaigns/builds from local-api while still using Supabase Auth (if configured):
VITE_APKZIO_DATA_SOURCE=rest

# Same value as APKZIO_ADMIN_API_KEY on local-api — required for /api/admin/* when ENFORCE_ADMIN_AUTH=1.
# Never ship this to a public-facing URL (browser-exposed). Internal/VPN operator consoles only.
# VITE_APKZIO_ADMIN_API_KEY=

# =============================================================================
# Supabase Auth (browser: anon key only). Optional for local mock-only runs.
# =============================================================================
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Same values as GitHub secrets if you sync from CI:
#   SB_ANON_KEY     → VITE_SUPABASE_ANON_KEY
#   (SUPABASE_URL)  → VITE_SUPABASE_URL

# =============================================================================
# Production / remote API (alternative to localhost)
# =============================================================================
# VITE_APKZIO_API_URL=https://api.apkzio.net
# VITE_APKZIO_DATA_SOURCE=rest

# Create Auth + app_owners for dashboard login (once per env):
#   Put SUPABASE_SERVICE_ROLE_KEY in backends/.env (never commit). Then from apkzio-admin:
#   npm run create-dashboard-user
# Optional: CREATE_ADMIN_EMAIL CREATE_ADMIN_PASSWORD for non-default test accounts.
# After that:
#   npm run verify-login
